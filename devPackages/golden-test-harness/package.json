{
  "name": "@proto-graphql/golden-test-harness",
  "version": "0.0.0",
  "description": "Reusable golden test harness for proto-graphql protoc plugins",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "sideEffects": false,
  "private": true,
  "scripts": {
    "build": "tsup",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@bufbuild/protobuf": "catalog:",
    "@bufbuild/protoplugin": "catalog:",
    "@proto-graphql/testapis-proto": "workspace:*",
    "typescript": "5.9.3"
  },
  "devDependencies": {
    "@proto-graphql/tsconfig": "workspace:*"
  }
}
