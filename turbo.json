{
  "$schema": "https://turborepo.org/schema.json",
  "tasks": {
    "clean": {
      "cache": false
    },
    "build": {
      "dependsOn": ["^build", "//#gen:testapis"]
    },
    "lint": {},
    "test": {
      "dependsOn": ["^build"]
    },
    "//#gen:testapis": {
      "cache": false
    },
    "@proto-graphql/golden-dataloader--testapis.dataloader.entity#test": {
      "dependsOn": ["^build", "protoc-gen-dataloader#test"]
    },
    "@proto-graphql/golden-dataloader--testapis.dataloader.group#test": {
      "dependsOn": ["^build", "protoc-gen-dataloader#test"]
    },
    "@proto-graphql/golden-pothos--testapis.service.basic--protobuf-es#test": {
      "dependsOn": ["^build", "protoc-gen-pothos#test"]
    },
    "@proto-graphql/golden-pothos--testapis.service.transforms--protobuf-es#test": {
      "dependsOn": ["^build", "protoc-gen-pothos#test"]
    }
  }
}
